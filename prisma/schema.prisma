// DataCube Tracker — Prisma schema
// Dev: SQLite (ไม่ต้องติดตั้งอะไร) | Production: เปลี่ยน provider เป็น "postgresql"
// หมายเหตุ: ใช้ String แทน enum เพื่อให้รองรับทั้ง SQLite และ PostgreSQL
// ค่าที่ใช้ได้ถูกกำหนดไว้ที่ src/lib/constants.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Supabase: Transaction pooler (port 6543)
  directUrl = env("DIRECT_URL")   // Supabase: Direct connection (port 5432) ใช้ตอน db push
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  passwordHash       String
  name               String
  role               String   @default("MEMBER") // ADMIN | MEMBER
  avatarUrl          String?
  mustChangePassword Boolean  @default(true) // บังคับเปลี่ยนรหัสผ่านครั้งแรก
  createdAt          DateTime @default(now())
  notifications      Notification[]
  activities         ActivityLog[]
  assignedTickets Ticket[] @relation("TicketAssignees")
  createdTickets  Ticket[] @relation("Creator")
  comments        Comment[]
  subtasks        Subtask[] @relation("SubtaskAssignee")
  attachments     Attachment[]
}

model Ticket {
  id             String    @id @default(cuid())
  number         Int       @unique // เลขงานสำหรับแสดงเป็น TCUBE-001
  title          String
  bu             String    @default("") // กลุ่ม BU ลูกค้า (ดู BUSINESS_UNITS ใน constants.ts)
  customer       String
  description    String?
  status         String    @default("NEW")       // NEW | ASSIGNED | IN_PROGRESS | REVIEW | DONE
  priority       String    @default("MEDIUM")    // LOW | MEDIUM | HIGH | URGENT
  jobType        String                          // ดู JOB_TYPES ใน constants.ts
  contactChannel String                          // ดู CHANNELS ใน constants.ts
  contactInfo    String?
  dueDate        DateTime?
  completedAt    DateTime? // วันที่เสร็จสิ้นจริง — ตั้งอัตโนมัติเมื่อสถานะเป็น "เสร็จสิ้น" หรือกรอกเอง
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // ผู้รับผิดชอบ — มอบหมายได้หลายคนต่องาน
  assignees      User[]    @relation("TicketAssignees")
  createdBy      User      @relation("Creator", fields: [createdById], references: [id])
  createdById    String
  comments       Comment[]
  subtasks       Subtask[]
  attachments    Attachment[]
  notifications  Notification[]
}

// กลุ่ม BU ลูกค้า — เพิ่ม/ลด/เปิดปิดได้จากหน้า "ทีมงาน" (เฉพาะแอดมิน)
model BusinessUnit {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// การแจ้งเตือน (แท็ก / มอบหมายงาน)
model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  String?
  type      String   @default("SYSTEM")
  dedupeKey String?
  message   String
  url       String?
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@unique([userId, dedupeKey])
  @@index([ticketId, createdAt])
}

// Global notification/SLA configuration. There is exactly one row: id = "default".
model NotificationSettings {
  id                      String  @id @default("default")
  notifyAssignment        Boolean @default(true)
  notifyStatusChange      Boolean @default(true)
  notifyComment           Boolean @default(true)
  notifyMention           Boolean @default(true)
  notifyDueSoon           Boolean @default(true)
  notifyOverdue           Boolean @default(true)
  dueSoonHours            Int     @default(48)
  overdueEscalationHours  Int     @default(24)
  updatedAt               DateTime @updatedAt
}

// บันทึกการใช้งานทั้งหมด (ใครทำอะไร เมื่อไหร่)
model ActivityLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  action    String
  detail    String
  createdAt DateTime @default(now())
}

// ไฟล์แนบและลิงก์ของแต่ละ ticket
model Attachment {
  id         String   @id @default(cuid())
  kind       String   // "file" | "link"
  name       String
  url        String
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId   String
  uploader   User     @relation(fields: [uploaderId], references: [id])
  uploaderId String
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId  String?
}

// งานย่อย (Subitems) ใต้แต่ละ ticket
model Subtask {
  id         String    @id @default(cuid())
  title      String
  done       Boolean   @default(false)
  dueDate    DateTime?
  createdAt  DateTime  @default(now())
  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId   String
  assignee   User?     @relation("SubtaskAssignee", fields: [assigneeId], references: [id])
  assigneeId String?
}

model Comment {
  id          String       @id @default(cuid())
  body        String
  createdAt   DateTime     @default(now())
  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    String
  author      User         @relation(fields: [authorId], references: [id])
  authorId    String
  attachments Attachment[]
  // ตอบกลับอัปเดต (reply)
  parent      Comment?     @relation("Reply", fields: [parentId], references: [id], onDelete: Cascade)
  parentId    String?
  replies     Comment[]    @relation("Reply")
}
