# Copy this file to .env before running Docker Compose.
# Use long, unique values in production. Do not commit .env.
POSTGRES_DB=datacube_tracker
POSTGRES_USER=datacube
POSTGRES_PASSWORD=replace-with-a-long-url-safe-password
AUTH_SECRET=change-this-to-a-long-random-secret-at-least-32-characters

APP_PORT=3000
TZ=Asia/Bangkok

# The seed is idempotent and creates the initial users/sample data. Set false
# after the first startup to skip it on later deployments.
SEED_DATABASE=true
